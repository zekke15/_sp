## 💻 4. Python 模擬程式實作

以下使用 Python 的 `threading.Lock`（模擬互斥鎖/筷子）與執行緒（模擬哲學家）來完整重現非死鎖的並行運作：

```python
import threading
import time
import random

class Philosopher(threading.Thread):
    def __init__(self, philosopher_id, left_chopstick, right_chopstick):
        super().__init__()
        self.philosopher_id = philosopher_id
        self.left_chopstick = left_chopstick
        self.right_chopstick = right_chopstick

    def run(self):
        for _ in range(3):  # 每個哲學家輪流吃 3 次飯
            self.think()
            self.eat()

    def think(self):
        print(f"🤔 哲學家 {self.philosopher_id} 正在沉思...")
        time.sleep(random.uniform(0.1, 0.3))

    def eat(self):
        # 💡 關鍵同步策略：打破「循環等待」
        # 奇數號先左後右；偶數號先右後左
        if self.philosopher_id % 2 == 1:
            first_chopstick = self.left_chopstick
            second_chopstick = self.right_chopstick
        else:
            first_chopstick = self.right_chopstick
            second_chopstick = self.left_chopstick

        # 嘗試獲取第一隻筷子
        first_chopstick.acquire()
        print(f"🥢 哲學家 {self.philosopher_id} 拿起了第一隻筷子")
        
        # 刻意微小延遲，若演算法有死鎖漏洞，此處最容易觸發卡死
        time.sleep(0.05) 
        
        # 嘗試獲取第二隻筷子
        second_chopstick.acquire()
        print(f"🍱 哲學家 {self.philosopher_id} 成功集齊兩隻筷子，開始享用大餐！")
        time.sleep(random.uniform(0.1, 0.3))
        
        # 用餐完畢，釋放資源
        second_chopstick.release()
        first_chopstick.release()
        print(f"🏳️ 哲學家 {self.philosopher_id} 吃飽了，優雅地放下了兩隻筷子。")

if __name__ == "__main__":
    num_philosophers = 5
    # 建立 5 隻筷子（5 把獨立的互斥鎖）
    chopsticks = [threading.Lock() for _ in range(num_philosophers)]
    
    # 初始化並啟動哲學家執行緒
    philosophers = []
    for i in range(num_philosophers):
        left = chopsticks[i]
        right = chopsticks[(i + 1) % num_philosophers]
        
        p = Philosopher(i, left, right)
        philosophers.append(p)
        p.start()

    # 等待所有執行緒執行完畢
    for p in philosophers:
        p.join()
        
    print("\n=== ✅ 所有哲學家都順利吃飽，系統無死鎖發生 ===")