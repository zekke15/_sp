void free_ast(AST *node) {
如果 (!node) 返回；
如果 (node->kind == AST_BINOP) {
free_ast(node->left);
free_ast(node->right);
} else if (node->kind == AST_ASSIGN || node->kind == AST_PRINT) {
free_ast(node->expr);
